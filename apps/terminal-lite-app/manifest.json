{
  "id": "com.cortexos.terminal-lite",
  "name": "Terminal",
  "version": "1.0.0",
  "description": "Command-line interface for file operations",
  "entry_point": "src/index.tsx",
  "icon": "icon.svg",
  "permissions": [
    {
      "permission": "files.read",
      "required": true,
      "reason": "Read files and directories"
    },
    {
      "permission": "files.write",
      "required": true,
      "reason": "Create and modify files"
    }
  ],
  "capabilities": {
    "ai": false,
    "background_execution": false,
    "autostart": false,
    "max_file_size": 104857600,
    "system_tray": false,
    "file_handlers": []
  },
  "min_os_version": "0.1.0",
  "author": {
    "name": "CortexOS Team"
  },
  "category": "development"
}
